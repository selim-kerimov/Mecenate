# This file lists all the environment variables your project needs to run.
# Copy this file to a new file named `.env` and fill in the values.

# URL of the backend OpenAPI schema (openapi.json).
# Consumed by the `codegen` npm script (see package.json), which runs
# openapi-rq against this URL to regenerate `./source/shared/openapi`.
# That folder contains the typed fetch client plus all React Query hooks
# (useGetPosts, usePostPostsByIdLike, etc.) — ALL network calls in the app
# go through these generated hooks, so if the backend contract changes you
# re-run `npm run codegen` to sync types and hooks with the latest schema.
EXPO_PUBLIC_OPEN_API_URL=

# Bearer token used to authenticate API requests. Read at app startup in
# `source/app/api/configureClient.ts`, which calls `client.setConfig({ auth })`
# on the generated fetch client so every request carries the token.
EXPO_PUBLIC_USER_ID=
